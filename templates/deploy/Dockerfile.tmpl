# {{project.name}} — generated by vibe_bootstrap. Customize as needed.
{{#if frontend}}
# Stage 1: Build frontend ({{frontend.framework}})
FROM node:20-alpine AS frontend-build
WORKDIR /app/{{frontend.directory}}
COPY {{frontend.directory}}/package.json {{frontend.directory}}/*lock* ./
# install_command runs from the frontend dir (already cd'd via WORKDIR above)
RUN corepack enable && {{frontend.package_manager}} install
COPY {{frontend.directory}}/ ./
ARG APP_VERSION=0.0.0
ARG BUILD_ENV=prod
RUN {{frontend.package_manager}} run build
{{/if}}

{{#if backend}}
# Stage 2: Backend ({{backend.language}} / {{backend.framework}})
FROM python:3.12-slim-bullseye AS backend
WORKDIR /app

COPY {{backend.directory}}/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY {{backend.directory}}/ /app/
{{#if frontend}}
# Frontend build output from stage 1
COPY --from=frontend-build /app/{{frontend.directory}}/dist/ /app/{{frontend.directory}}/dist/
{{/if}}

COPY docker-entrypoint.sh /app/docker-entrypoint.sh
RUN sed -i 's/\r$//' /app/docker-entrypoint.sh && chmod +x /app/docker-entrypoint.sh

EXPOSE {{backend.server_port}}

ENTRYPOINT ["/app/docker-entrypoint.sh"]
# Shell form (not JSON-array) so multi-word server_command parses correctly.
# Switch to exec form (JSON array of args) for production hardening.
CMD {{backend.server_command}}
{{/if}}
